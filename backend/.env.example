# Anthropic — required for AI Q&A
ANTHROPIC_API_KEY=

# Supabase — optional; the backend falls back to local file storage if blank
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# CORS — comma-separated origins allowed to call the API
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Limits
MAX_FILE_SIZE_MB=50

# Storage — local dir used when Supabase is not configured
LOCAL_STORAGE_DIR=./storage
